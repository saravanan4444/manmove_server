# ── ManMove Server — Production Environment Template ──
# Copy this file to .env and fill in values for each client deployment

PORT=3010
NODE_ENV=production

# MongoDB Atlas connection string (one DB per client)
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<client_name>

# JWT — generate unique secrets per client: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate_unique_64_char_hex>
JWT_REFRESH_SECRET=<generate_unique_64_char_hex>

# Email (for alerts, password reset)
EMAIL_HOST=<smtp_host>
EMAIL_USER=<smtp_email>
EMAIL_PASS=<smtp_password>
ALERT_EMAIL=<superadmin_alert_email>

# Server public URL
SERVER_URL=https://app.manmove.in

# Allowed frontend origins
ALLOWED_ORIGINS=https://app.manmove.in

# Cloudinary (photo uploads)
CLOUDINARY_CLOUD_NAME=<cloudinary_name>
CLOUDINARY_API_KEY=<cloudinary_key>
CLOUDINARY_API_SECRET=<cloudinary_secret>

# FCM push notifications
FCM_SERVER_KEY=<firebase_server_key>

# Sentry error tracking (optional)
SENTRY_DSN=

# Redis (optional, for rate limiting at scale)
# REDIS_URL=redis://127.0.0.1:6379
